PORT=8080
# Cloud Run + Cloud SQL (socket Unix). Debe coincidir con --add-cloudsql-instances.
DB_HOST=/cloudsql/it-fab-contenido-edu-4:us-central1:inventario-fab
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
# En socket Unix de Cloud SQL suele ser false; en IP pública suele ser true.
DB_SSL=false
NODE_ENV=production
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=28800
# Orígenes CORS separados por coma (ej. https://tu-front.run.app). Local por defecto en código.
CORS_ORIGIN=
